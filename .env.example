# =============================================================================
# Graft CRM — copy to `.env` and fill in values.
# All variables are read via `src/lib/env.ts` (do not read process.env elsewhere).
# =============================================================================

# --- Core (required) ---
# PostgreSQL only (`pg` driver). Do not use SQLite `file:./…` — dev falls back to Docker URL + warning if you do.
# Local Docker default matches docker-compose.yml:
# DATABASE_URL="postgresql://graft:graft@localhost:5432/graft_crm"
DATABASE_URL=""
AUTH_SECRET=""
AUTH_URL=""
# Sign-in: email + password; open sign-up creates users unless AUTH_INVITE_ONLY=true.
# AUTH_INVITE_ONLY=true

# --- Groq (AI summaries + voice transcription) — free tier at console.groq.com ---
GROQ_API_KEY=""
GROQ_MODEL=""
GROQ_WHISPER_MODEL=""

# --- Google Calendar (optional — schedule meetings + send invites) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Defaults to ${AUTH_URL}/api/calendar/google/callback if unset:
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/google/callback"
# Consent screen must include: openid, userinfo.email, userinfo.profile, calendar.events (enable Calendar API).

# --- Email reminders via Resend (optional — free tier at resend.com) ---
RESEND_API_KEY=""
EMAIL_FROM=""
# Resend test mode often only accepts mail to your Resend-login inbox; redirect all digest mail there:
# EMAIL_DIGEST_OUTBOUND_TO="you@gmail.com"

# --- Cron: POST /api/cron/reminders (required in production) ---
# Generate: openssl rand -hex 32
CRON_SECRET=""

# --- Wispr webhook (optional — in-app voice uses Groq instead) ---
# Generate: openssl rand -hex 32
WISPR_WEBHOOK_SECRET=""
