generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Workspace {
  id                  String              @id @default(cuid())
  name                String
  capitalSplitBuckets Json                @default("[]")
  users               User[]
  companies           Company[]
  stages              RelationshipStage[]
  capitalReceipts     CapitalReceipt[]
  calendarEvents      CalendarEvent[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model User {
  id                  String          @id @default(cuid())
  name                String?
  email               String          @unique
  emailVerified       DateTime?
  image               String?
  role                String          @default("member")
  workspaceId         String
  workspace           Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownedCompanies      Company[]         @relation("CompanyOwner")
  ownedDeals          Deal[]            @relation("DealOwner")
  ownedPilots         Pilot[]           @relation("PilotOwner")
  ownedPartners       PartnerProfile[]  @relation("PartnerOwner")
  ownedTasks          FollowUpTask[]    @relation("TaskOwner")
  createdTasks        FollowUpTask[]    @relation("TaskCreator")
  createdInteractions Interaction[]     @relation("InteractionCreator")
  activityEvents      ActivityEvent[]   @relation("ActivityActor")
  capitalReceipts     CapitalReceipt[]  @relation("CapitalReceiptCreator")
  calendarAccounts    CalendarAccount[]
  accounts            Account[]
  sessions            Session[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RelationshipStage {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key         String
  label       String
  sortOrder   Int
  companies   Company[]

  @@unique([workspaceId, key])
}

model Company {
  id                  String             @id @default(cuid())
  workspaceId         String
  workspace           Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                String
  website             String?
  domain              String?
  description         String?
  relationshipStageId String?
  relationshipStage   RelationshipStage? @relation(fields: [relationshipStageId], references: [id], onDelete: SetNull)
  tags                Json               @default("[]")
  needs               String?
  accountOwnerId      String
  accountOwner        User               @relation("CompanyOwner", fields: [accountOwnerId], references: [id], onDelete: Restrict)
  contacts            Contact[]
  deals               Deal[]
  pilots              Pilot[]
  investorProfile     InvestorProfile?
  partnerProfile      PartnerProfile?
  wineryProfile       WineryProfile?
  interactions        Interaction[]
  followUpTasks       FollowUpTask[]
  activityEvents      ActivityEvent[]
  calendarEvents      CalendarEvent[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([workspaceId, name])
  @@index([accountOwnerId])
  @@index([relationshipStageId])
}

model Contact {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  linkedinUrl    String?
  title          String?
  contactRole    String?
  isPrimary      Boolean         @default(false)
  notes          String?
  interactions   Interaction[]
  followUpTasks  FollowUpTask[]
  calendarEvents CalendarEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId])
  @@index([name])
}

model Interaction {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  type            String
  occurredAt      DateTime
  notes           String?
  source          String         @default("manual")
  transcript      String?
  aiSummary       String?
  aiNeeds         Json?
  aiSuggestedTasks Json?
  aiStageHint     String?
  aiTagHints      Json?
  calendarEventId String?        @unique
  calendarEvent   CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User           @relation("InteractionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  followUpTasks   FollowUpTask[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId, occurredAt])
  @@index([contactId])
}

model Deal {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  stage         String         @default("open")
  valueEstimate Float?
  expectedClose DateTime?
  ownerId       String?
  owner         User?          @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  notes         String?
  pilots        Pilot[]
  followUpTasks FollowUpTask[]
  capitalReceipts CapitalReceipt[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId, stage])
  @@index([ownerId])
}

model CalendarAccount {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String          @default("demo")
  externalAccountId String?
  displayName       String?
  status            String          @default("connected")
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  syncCursor        String?
  connectedAt       DateTime        @default(now())
  events            CalendarEvent[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([userId, provider, externalAccountId])
  @@index([userId])
}

model CalendarEvent {
  id                 String           @id @default(cuid())
  workspaceId        String
  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  calendarAccountId  String
  calendarAccount    CalendarAccount  @relation(fields: [calendarAccountId], references: [id], onDelete: Cascade)
  externalId         String
  title              String
  description        String?
  startsAt           DateTime
  endsAt             DateTime
  location           String?
  meetingUrl         String?
  organizerEmail     String?
  attendees          Json             @default("[]")
  companyId          String?
  company            Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId          String?
  contact            Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  linkStatus         String           @default("unmatched")
  interaction        Interaction?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([calendarAccountId, externalId])
  @@index([workspaceId, startsAt])
  @@index([companyId])
  @@index([contactId])
}

model CapitalReceipt {
  id            String    @id @default(cuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  amount        Float
  title         String
  source        String    @default("deal")
  dealId        String?
  deal          Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  receivedAt    DateTime
  notes         String?
  createdById   String
  createdBy     User      @relation("CapitalReceiptCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId, receivedAt])
  @@index([dealId])
}

model Pilot {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dealId          String?
  deal            Deal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  name            String
  status          String         @default("planned")
  startAt         DateTime?
  targetEndAt     DateTime?
  successCriteria String?
  ownerId         String?
  owner           User?          @relation("PilotOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  notes           String?
  followUpTasks   FollowUpTask[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId, status])
  @@index([ownerId])
}

model InvestorProfile {
  id              String   @id @default(cuid())
  companyId       String   @unique
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fundName        String?
  checkSizeBand   String?
  thesisTags      Json     @default("[]")
  warmIntroSource String?
  stage           String   @default("prospecting")
  nextStep        String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WineryProfile {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  region                String?
  varietals             Json     @default("[]")
  annualProductionCases Int?
  distributionModel     String?
  tastingRoomStatus     String?
  winemakerName         String?
  established           Int?
  websiteShop           String?
  nextStep              String?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PartnerProfile {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partnerType      String?
  programStatus    String   @default("exploring")
  ownerId          String?
  owner            User?    @relation("PartnerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  integrationNotes String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model FollowUpTask {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId        String?
  deal          Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  pilotId       String?
  pilot         Pilot?       @relation(fields: [pilotId], references: [id], onDelete: SetNull)
  interactionId String?
  interaction   Interaction? @relation(fields: [interactionId], references: [id], onDelete: SetNull)
  title         String
  description   String?
  status        String       @default("open")
  dueAt         DateTime?
  ownerId       String?
  owner         User?        @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([companyId, status])
  @@index([ownerId, status, dueAt])
  @@index([status, dueAt])
}

model ActivityEvent {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  kind      String
  summary   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
}
